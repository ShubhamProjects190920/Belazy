# ─────────────────────────────────────────────
#  AI Project Controls Platform — Environment
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Security ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_project_controls

# ── Frontend ──────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Email (SMTP) ──────────────────────────────
# Use any SMTP provider: Gmail, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@yourcompany.com
EMAILS_FROM_NAME=AI Project Controls

# ── Token Expiry ──────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=48
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24
